{
  "comments": "Matching takes place in the order defined in this file. Place code matches before name matches, and smaller regions before larger ones.",
  "regionWmsMap": {
        {%- for coll in m_urls.collections.collections | list  -%}
            "{{coll.id}}": {
                "layerName": "default",
                "server": "https://data.apps.fao.org/geospatial/v2/api/maps/tiles/catalogs/{{m.catalog}}/tiles/{z}/{x}/{y}.mvt?collections={{coll.id}}",
                "regionProp": "external_id",
                "uniqueIdProp": "fid",
                "aliases": [
                    "{{coll.id}}"
                ],
                "digits": 255,
                "description": "{{coll.title}}",        
                "regionIdsFile": "https://data.apps.fao.org/geospatial/v2/api/tools/template/interpolate?t=%7B%22layer%22%3A%20%22default%22%2C%20%22property%22%3A%20%22external_id%22%2C%20%22values%22%3A%20%7B%7B%20m_urls.coll_items.features%20%7C%20map%28attribute%3D%27properties.external_id%27%29%20%7C%20list%7D%7D%7D&m_urls=%7B%22coll_items%22%3A%20%22https%3A%2F%2Fdata.apps.fao.org%2Fgeospatial%2Fv2%2Fapi%2Fcatalog%2Fstac%2Fcatalogs%2F{{m.catalog}}%2Fcollections%2F{{coll.id}}%2Fitems%3Flimit%3D10%26offset%3D0%22%7D&r_mt=application%2Fjson",
                "serverType": "MVT",
                "serverSubdomains": [],
                "serverMinZoom": 0,
                "serverMaxNativeZoom": 12,
                "serverMaxZoom": 28,
                "bbox": {{coll.extent.spatial.bbox[0]}}
            }{%- if not loop.last -%},{%- endif -%}    
        {%- endfor -%}
    }
}
